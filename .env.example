DB_HOST=localhost
DB_PORT=3306
DB_NAME=jimi_tracker
DB_USER=root
DB_PASS=your_password_here
WEBHOOK_TOKEN=your_token_here
SYSTEM_VERSION=4.1.0
FILE_STORAGE_URL=http://your-server:23010/download/
STREAM_URL=http://your-server:8881
# Vídeo ao vivo/playback (JT/T 1078): endereço que o DEVICE alcança para
# publicar o stream (comandos 37121/37377). Sem override, o IP é o host de
# STREAM_URL e as portas são as padrão do iothub-media (10002/10003).
#VIDEO_INGEST_IP=your-server
#VIDEO_INGEST_PORT=10002
#VIDEO_PLAYBACK_PORT=10003
# Use o IP da LAN do host (não localhost) — consistente com o pushURL dos
# containers do IoTHub, que só alcançam o host pelo IP da rede (ex.: 10.1.0.43)
IOTHUB_COMMAND_URL=http://10.1.0.43:10088/api/device/sendInstruct
IOTHUB_API_TOKEN=123
# Gatilho automático de vídeo de evento (ocorrência nova em câmera JT/T →
# proNo 37384, upload do anexo do alarme pelo alarmLabel). 0 desliga.
# ATTACH_UPLOAD_*: endereço do attachment server do IoTHub QUE O DEVICE
# ALCANÇA (jimi-tracker-upload-process; sem override, usa o IP de ingest do
# vídeo e a porta padrão 21188).
#AUTO_VIDEO_REQUEST=1
#AUTO_VIDEO_TIMEOUT=35
#ATTACH_UPLOAD_IP=your-server
#ATTACH_UPLOAD_PORT=21188
# Logging (core/Logger.php → logs/webhook_YYYY-MM-DD.log).
# LOG_LEVEL=DEBUG liga o RAW_WEBHOOK_DATA (payload bruto de cada webhook) —
# usar temporariamente para diagnosticar device com payload inesperado.
# Retenção/teto aplicados pelo scripts/log_cleanup.php (cron diário 03:10,
# instalado via scripts/crontab-setup.sh).
#LOG_LEVEL=INFO
#LOG_RETENTION_DAYS=30
#LOG_MAX_SIZE_MB=10
