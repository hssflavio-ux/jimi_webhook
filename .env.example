DB_HOST=localhost
DB_PORT=3306
DB_NAME=jimi_tracker
DB_USER=root
DB_PASS=your_password_here
WEBHOOK_TOKEN=your_token_here
SYSTEM_VERSION=4.1.0
FILE_STORAGE_URL=http://your-server:23010/download/
STREAM_URL=http://your-server:8881
# Vídeo ao vivo/playback (JT/T 1078): endereço que o DEVICE alcança para
# publicar o stream (comandos 37121/37377). Sem override, o IP é o host de
# STREAM_URL e as portas são as padrão do iothub-media (10002/10003).
#VIDEO_INGEST_IP=your-server
#VIDEO_INGEST_PORT=10002
#VIDEO_PLAYBACK_PORT=10003
# Use o IP da LAN do host (não localhost) — consistente com o pushURL dos
# containers do IoTHub, que só alcançam o host pelo IP da rede (ex.: 10.1.0.43)
IOTHUB_COMMAND_URL=http://10.1.0.43:10088/api/device/sendInstruct
IOTHUB_API_TOKEN=123
